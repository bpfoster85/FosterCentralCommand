{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/sw.js", "/workbox-*.js", "/manifest.webmanifest", "/*.{css,js,ico,png,jpg,jpeg,gif,svg,webp,woff,woff2,ttf,map,json,webmanifest}"]
  },
  "mimeTypes": {
    ".json": "application/json",
    ".webmanifest": "application/manifest+json"
  },
  "routes": [
    {
      "route": "/sw.js",
      "headers": {
        "cache-control": "no-cache, no-store, must-revalidate",
        "service-worker-allowed": "/"
      }
    },
    {
      "route": "/manifest.webmanifest",
      "headers": {
        "cache-control": "no-cache"
      }
    }
  ]
}
